rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // NEW RULE: Support for multiple systems/addresses
    // Path: /artifacts/solar-forecaster-63320/users/{userId}/systems/{systemId}/{document}
    match /artifacts/solar-forecaster-63320/users/{userId}/systems/{systemId}/{document} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId 
                   && (document != 'config' || request.resource.data.schemaVersion >= 2);
    }

    // LEGACY RULE: Support for original single-system path (required for migration)
    match /artifacts/solar-forecaster-63320/users/{userId}/solar_app/{document} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId 
                   && (document != 'config' || request.resource.data.schemaVersion >= 2);
    }
    
    // Allow users to submit feedback
    match /feedback/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // PUBLIC API: Allow anyone to read the forecast data if they have the UID
    // This allows Home Assistant to pull data without an API key
    match /public_forecasts/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Default: Deny everything else explicitly
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
