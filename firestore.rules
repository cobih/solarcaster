rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Standard path for Solarcaster data
    // Path: /artifacts/solar-forecaster-63320/users/{userId}/solar_app/{document}
    match /artifacts/{appId}/users/{userId}/solar_app/{allPaths=**} {
      // Allow read/write if the user is authenticated and is accessing their own UID
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Legacy or root level matching just in case appId is omitted in future versions
    match /artifacts/{appId}/users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Default: Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}